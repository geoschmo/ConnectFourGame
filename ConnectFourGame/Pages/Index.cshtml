@page
@model ConnectFourGame.Pages.IndexModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <title>Connect Four</title>
    <link rel="stylesheet" href="~/css/styles.css" asp-append-version="true" />
</head>
<body>
    <a href="@Model.PortfolioUrl" class="back-link">&larr; Back to portfolio</a>

    <main class="app-shell">
        <section class="hero-panel">
            <p class="eyebrow">Browser Game</p>
            <h1>Connect Four</h1>
            <p class="subtitle">Drop discs, build a line of four, and play against the computer, a local friend, or a remote opponent by invite link.</p>

            <div class="control-grid">
                <label class="field">
                    <span>Mode</span>
                    <select id="mode-select">
                        <option value="cpu" selected>Player vs Computer</option>
                        <option value="local">Local 2 Players</option>
                        <option value="remote">Remote 2 Players</option>
                    </select>
                </label>

                <label class="field" id="difficulty-field">
                    <span>Difficulty</span>
                    <select id="difficulty-select">
                        <option value="easy">Easy</option>
                        <option value="normal" selected="@(Model.SelectedDifficulty == "normal")">Normal</option>
                        <option value="hard" selected="@(Model.SelectedDifficulty == "hard")">Hard</option>
                    </select>
                </label>
            </div>

            <section id="remote-panel" class="remote-card hidden" aria-label="online multiplayer controls">
                <p class="remote-title">Online Match</p>

                <div class="button-row remote-actions">
                    <button id="create-room-btn" class="btn btn-secondary" type="button">Create Invite Link</button>
                </div>

                <label class="field">
                    <span>Join with room code</span>
                    <div class="join-row">
                        <input id="room-code-input" type="text" maxlength="6" autocomplete="off" placeholder="Enter code" />
                        <button id="join-room-btn" class="btn btn-primary" type="button">Join</button>
                    </div>
                </label>

                <div id="invite-shell" class="invite-shell hidden">
                    <p class="invite-label">Current room</p>
                    <p id="room-code-display" class="room-code-display">------</p>
                    <button id="copy-invite-btn" class="btn btn-secondary" type="button">Copy Invite Link</button>
                </div>
            </section>

            <div class="button-row">
                <button id="new-game-btn" class="btn btn-primary">New Game</button>
                <button id="leave-room-btn" class="btn btn-secondary hidden" type="button">Leave Room</button>
            </div>

            <div class="status-card">
                <p id="status-text">Red starts. Pick a column.</p>
                <p id="hint-text">Use the column buttons above the board to place a disc.</p>
            </div>
        </section>

        <section class="board-panel">
            <div class="board-header">
                <p class="board-label">Game Board</p>
                <p id="turn-indicator" class="turn-indicator red">Red to move</p>
            </div>

            <div id="column-controls" class="column-controls" aria-label="column controls"></div>
            <div id="board" class="board" role="grid" aria-label="Connect Four board"></div>

            <div class="legend">
                <span><i class="disc preview red"></i> Red</span>
                <span><i class="disc preview yellow"></i> Yellow</span>
                <span><i class="win-marker"></i> Winning discs glow</span>
            </div>
        </section>
    </main>

    <script>
        window.connectFourConfig = {
            selectedDifficulty: '@Model.SelectedDifficulty',
            inviteRoomCode: '@(Model.Room ?? "")',
            gameHubUrl: '@Url.Content("~/gameHub")'
        };
    </script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.7/signalr.min.js"></script>
    <script src="~/js/game.js" asp-append-version="true"></script>
</body>
</html>
